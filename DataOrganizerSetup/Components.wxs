<!--
	Component - https://docs.firegiant.com/wix/schema/wxs/component
	ComponentGroup - https://docs.firegiant.com/wix/schema/wxs/componentgroup
	File - https://docs.firegiant.com/wix/schema/wxs/file
	Fragment - https://docs.firegiant.com/wix/schema/wxs/fragment
	Wix - https://docs.firegiant.com/wix/schema/wxs/wix
-->

<?include Predefines.wxi ?>

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
	<Fragment>
		<ComponentGroup Id="Components"
						Directory="INSTALLFOLDER">
			<Component Guid="$(var.ProductComponentGUID)">
				<File Source="Components.wxs" />
			</Component>
		</ComponentGroup>
	</Fragment>
</Wix>
