<?include Predefines.wxi ?>

<!-- https://docs.firegiant.com/wix/schema/wxs/wix -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
	
	<!-- https://docs.firegiant.com/wix/schema/wxs/package -->
	<Package Name="$(var.PackageName)"
			 Manufacturer="$(var.Manufacturer)"
			 Version="$(var.ProductVersion)"
			 UpgradeCode="$(var.UpgradeCode)">
		
		<!-- https://docs.firegiant.com/wix/schema/wxs/majorupgrade -->
		<MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeError)" />

		<!-- https://docs.firegiant.com/wix/schema/wxs/feature -->
		<Feature Id="Main">
			
			<!-- https://docs.firegiant.com/wix/schema/wxs/componentgroup -->
			<ComponentGroupRef Id="Components" />
		</Feature>
	</Package>
</Wix>
