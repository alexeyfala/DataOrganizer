<Project>
	<PropertyGroup>
		<AppName>Data Organizer</AppName>
		<AppNameAsOneWord>DataOrganizer</AppNameAsOneWord>
		<AppIconPath>..\$(AppNameAsOneWord)\Assets\Logo.ico</AppIconPath>
		<AppVersion>2.0.0</AppVersion>
		<Manufacturer>Alexey Fala</Manufacturer>
		<MsiOutputName>$(AppNameAsOneWord)-$(Platform)-$(AppVersion)</MsiOutputName>
	</PropertyGroup>
</Project>