<Project Sdk="WixToolset.Sdk/6.0.2">
	<PropertyGroup>
		<OutputName>$(MsiOutputName)</OutputName>
		<OutputPath>..\Publish</OutputPath>
		<DefineConstants>$(DefineConstants);AppName=$(AppName)</DefineConstants>
		<DefineConstants>$(DefineConstants);AppNameAsOneWord=$(AppNameAsOneWord)</DefineConstants>
		<DefineConstants>$(DefineConstants);Manufacturer=$(Manufacturer)</DefineConstants>
		<DefineConstants>$(DefineConstants);AppVersion=$(AppVersion)</DefineConstants>
		<ProjectReferenceName>$(AppNameAsOneWord).Desktop</ProjectReferenceName>
		<Cultures>;</Cultures>
	</PropertyGroup>
	<ItemGroup>
		<Content Include="CustomDialogs\LaunchAppOnExit.wxi" />
		<Content Include="Predefines.wxi" />
	</ItemGroup>
	<ItemGroup>
		<None Include="LICENSE.rtf" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="WixToolset.UI.wixext"
						  Version="6.0.2" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\DataOrganizer.Desktop\DataOrganizer.Desktop.csproj" />
	</ItemGroup>
	<Target Name="PreBuild"
			BeforeTargets="PreBuildEvent">
		<Exec Command="dotnet publish ..\$(ProjectReferenceName)\$(ProjectReferenceName).csproj -c:$(Configuration) -r:win-x64 -p:DebugSymbols=false -p:PublishDir=&quot;bin\$(Configuration)\net10.0\Publish&quot;" />
	</Target>
	<Target Name="PostBuild"
			AfterTargets="PostBuildEvent">
		<Exec Command="del /f $(OutputPath)\*.wixpdb" />
		<Exec Command="start $(OutputPath)" />
	</Target>
</Project>