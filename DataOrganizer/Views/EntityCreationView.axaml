<UserControl
	x:Class="DataOrganizer.Views.EntityCreationView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:assists="using:Material.Styles.Assists"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:materialIcons="using:Material.Icons.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:prop="using:Shared.Properties"
	xmlns:vm="using:DataOrganizer.ViewModels"
	x:DataType="vm:EntityCreationViewModel"
	Theme="{StaticResource DialogTheme}"
	mc:Ignorable="d">

	<Grid
		ColumnDefinitions="*,Auto"
		RowDefinitions="*,Auto,Auto"
		RowSpacing="{StaticResource ElementSpacing}">

		<StackPanel
			Grid.Row="0"
			Grid.Column="0"
			Grid.ColumnSpan=""
			Orientation="Vertical"
			Spacing="{StaticResource ElementSpacing}">

			<StackPanel.Resources>
				<Thickness x:Key="FileMargin">12.0,0.0,0.0,0.0</Thickness>
			</StackPanel.Resources>

			<StackPanel.Styles>
				<Style Selector="materialIcons|MaterialIcon">
					<Setter Property="Width" Value="{StaticResource EntityTypeIconSize}" />
					<Setter Property="Height" Value="{StaticResource EntityTypeIconSize}" />
					<Setter Property="Margin" Value="4.0,0.0" />
				</Style>

				<Style Selector="TextBlock">
					<Setter Property="VerticalAlignment" Value="Center" />
				</Style>

				<Style Selector="StackPanel">
					<Setter Property="Orientation" Value="Horizontal" />
				</Style>
			</StackPanel.Styles>

			<RadioButton IsChecked="{Binding IsFolderSelected, Mode=TwoWay}">
				<StackPanel>
					<materialIcons:MaterialIcon
						Foreground="{StaticResource FolderBrush}"
						Kind="{StaticResource FolderIconKind}" />

					<TextBlock Text="{x:Static prop:Strings.Folder}" />
				</StackPanel>
			</RadioButton>

			<RadioButton
				Margin="{StaticResource FileMargin}"
				IsChecked="{Binding IsFileSelected, Mode=TwoWay}">
				<StackPanel>
					<materialIcons:MaterialIcon
						Foreground="{StaticResource FileBrush}"
						Kind="{StaticResource FileIconKind}" />

					<TextBlock Text="{x:Static prop:Strings.File}" />
				</StackPanel>
			</RadioButton>

			<RadioButton
				Margin="{StaticResource FileMargin}"
				IsChecked="{Binding IsDatasetSelected, Mode=TwoWay}">
				<StackPanel>
					<materialIcons:MaterialIcon
						Foreground="{StaticResource FileBrush}"
						Kind="{StaticResource DatasetIconKind}" />

					<TextBlock Text="{x:Static prop:Strings.Dataset}" />
				</StackPanel>
			</RadioButton>
		</StackPanel>

		<TextBox
			Grid.Row="1"
			Grid.Column="0"
			Grid.ColumnSpan="2"
			assists:TextFieldAssist.Label="{Binding NameInputHint, Mode=OneWay}"
			Classes="clearButton"
			Text="{Binding Name, Mode=TwoWay}"
			UseFloatingPlaceholder="True">
			<Interaction.Behaviors>
				<AutoFocusBehavior />
				<AutoSelectBehavior />
			</Interaction.Behaviors>
		</TextBox>

		<UniformGrid
			Grid.Row="2"
			Grid.Column="1"
			ColumnSpacing="{StaticResource ElementSpacing}"
			Columns="2">
			<UniformGrid.Styles>
				<Style Selector="Button">
					<Setter Property="Theme" Value="{StaticResource MaterialFlatButton}" />
				</Style>
			</UniformGrid.Styles>

			<Button
				Classes="primary"
				Command="{Binding SaveCommand}"
				Content="{x:Static prop:Strings.Add}"
				IsDefault="True" />

			<Button
				Classes="primary"
				Command="{Binding CancelCommand}"
				Content="{x:Static prop:Strings.Cancel}"
				IsCancel="True" />
		</UniformGrid>
	</Grid>
</UserControl>
