<UserControl
	x:Class="DataOrganizer.Views.SettingsView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:globalization="using:System.Globalization"
	xmlns:materialControls="using:Material.Styles.Controls"
	xmlns:materialIcons="using:Material.Icons.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:prop="using:Shared.Properties"
	xmlns:system="using:System"
	xmlns:vm="using:DataOrganizer.ViewModels"
	MinWidth="500.0"
	Padding="{StaticResource DialogIndent}"
	x:DataType="vm:SettingsViewModel"
	mc:Ignorable="d">

	<Grid
		RowDefinitions="Auto,*"
		RowSpacing="{StaticResource ElementSpacing}">
		<Button
			Grid.Row="0"
			HorizontalAlignment="Left"
			Classes="primary"
			Command="{Binding SaveAndCloseCommand}"
			Content="{materialIcons:MaterialIconTextExt Kind=ContentSaveOutline,
			                                            IconSize={StaticResource ToolBarIconSize}}"
			Theme="{StaticResource MaterialFlatButton}"
			ToolTip.Tip="{x:Static prop:Strings.SaveAndClose}" />

		<ScrollViewer
			Grid.Row="1"
			HorizontalScrollBarVisibility="Disabled"
			VerticalScrollBarVisibility="Auto">
			<Grid
				RowDefinitions="*,*,*,*"
				RowSpacing="{StaticResource ElementSpacing}">

				<Grid.Resources>
					<system:Double x:Key="ComboBoxHeight">18.0</system:Double>
				</Grid.Resources>

				<Grid.Styles>
					<Style Selector="Border.HelpIconBorderStyle">
						<Setter Property="VerticalAlignment" Value="Center" />
						<Setter Property="Background" Value="Transparent" />
						<Setter Property="Cursor" Value="Help" />
						<Setter Property="Child">
							<Template>
								<materialIcons:MaterialIcon
									Foreground="DodgerBlue"
									Kind="HelpCircleOutline" />
							</Template>
						</Setter>
					</Style>
				</Grid.Styles>

				<HeaderedContentControl
					Grid.Row="0"
					Classes="ClassicGroupBoxStyle"
					Header="{x:Static prop:Strings.ColorScheme}">
					<StackPanel
						Margin="{StaticResource DialogIndent}"
						Orientation="Vertical"
						Spacing="{StaticResource ElementSpacing}">

						<HeaderedContentControl
							Classes="GroupBoxStyle"
							Header="{x:Static prop:Strings.Theme}">
							<materialControls:Card>
								<materialControls:Card.Styles>
									<Style Selector="RadioButton">
										<Setter Property="HorizontalContentAlignment" Value="Center" />
										<Setter Property="Theme" Value="{StaticResource MaterialButtonlikeRadioButton}" />
									</Style>
								</materialControls:Card.Styles>

								<UniformGrid Columns="3">
									<RadioButton
										Classes="accent"
										Content="{x:Static prop:Strings.System}"
										IsChecked="{Binding IsInheritTheme, Mode=TwoWay}" />

									<RadioButton
										Classes="accent"
										Content="{x:Static prop:Strings.Light}"
										IsChecked="{Binding IsLightTheme, Mode=TwoWay}" />

									<RadioButton
										Classes="accent"
										Content="{x:Static prop:Strings.Dark}"
										IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" />
								</UniformGrid>
							</materialControls:Card>
						</HeaderedContentControl>

						<UniformGrid
							ColumnSpacing="{StaticResource ElementSpacing}"
							Columns="2">
							<HeaderedContentControl
								Classes="ClassicGroupBoxStyle"
								Header="{x:Static prop:Strings.PrimaryColor}">
								<ComboBox
									Height="{StaticResource ComboBoxHeight}"
									ItemTemplate="{StaticResource MaterialDesignColorSampleTemplate}"
									ItemsSource="{Binding PrimaryColors, Mode=OneTime}"
									SelectedItem="{Binding PrimaryColor, Mode=TwoWay}" />
							</HeaderedContentControl>

							<HeaderedContentControl
								Classes="ClassicGroupBoxStyle"
								Header="{x:Static prop:Strings.SecondaryColor}">
								<ComboBox
									Height="{StaticResource ComboBoxHeight}"
									ItemTemplate="{StaticResource MaterialDesignColorSampleTemplate}"
									ItemsSource="{Binding SecondaryColors, Mode=OneTime}"
									SelectedItem="{Binding SecondaryColor, Mode=TwoWay}" />
							</HeaderedContentControl>
						</UniformGrid>
					</StackPanel>
				</HeaderedContentControl>

				<Grid
					Grid.Row="1"
					ColumnDefinitions="*,Auto"
					ColumnSpacing="{StaticResource ElementSpacing}">
					<HeaderedContentControl
						Grid.Column="0"
						Classes="ClassicGroupBoxStyle"
						Header="{x:Static prop:Strings.Hotkeys}">
						<CheckBox
							Margin="10.0"
							Content="{x:Static prop:Strings.EnableHotkeyTracking}"
							IsChecked="{Binding TrackHotkeys, Mode=TwoWay}" />
					</HeaderedContentControl>

					<Border
						Grid.Column="1"
						Margin="0.0,9.0,0.0,0.0"
						Classes="HelpIconBorderStyle"
						ToolTip.Tip="{x:Static prop:Strings.DescriptionOfUseHotkeys}" />
				</Grid>

				<Grid
					Grid.Row="2"
					ColumnDefinitions="*,Auto"
					ColumnSpacing="{StaticResource ElementSpacing}">
					<HeaderedContentControl
						Grid.Column="0"
						Classes="ClassicGroupBoxStyle"
						Header="{x:Static prop:Strings.Clipboard}">
						<StackPanel
							Margin="10.0"
							Orientation="Vertical"
							Spacing="{StaticResource ElementSpacing}">
							<CheckBox
								Content="{x:Static prop:Strings.EnableClipboardHistoryTracking}"
								IsChecked="{Binding TrackClipboardHistory, Mode=TwoWay}" />

							<CheckBox
								Content="{x:Static prop:Strings.PersistHistoryBetweenSessions}"
								IsChecked="{Binding PersistClipboardHistory, Mode=TwoWay}"
								IsEnabled="{Binding TrackClipboardHistory}" />
						</StackPanel>
					</HeaderedContentControl>

					<Border
						Grid.Column="1"
						Margin="0.0,9.0,0.0,0.0"
						Classes="HelpIconBorderStyle"
						ToolTip.Tip="{x:Static prop:Strings.DescriptionOfUseClipboard}" />
				</Grid>

				<Grid
					Grid.Row="3"
					ColumnDefinitions="*,Auto"
					ColumnSpacing="{StaticResource ElementSpacing}">
					<HeaderedContentControl
						Grid.Column="0"
						Classes="ClassicGroupBoxStyle"
						Header="{x:Static prop:Strings.Language}">
						<ComboBox
							Height="{StaticResource ComboBoxHeight}"
							ItemsSource="{Binding Languages, Mode=OneTime}"
							SelectedItem="{Binding Language, Mode=TwoWay}">
							<ComboBox.ItemTemplate>
								<DataTemplate x:DataType="globalization:CultureInfo">
									<TextBlock Text="{Binding EnglishName, Mode=OneTime}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</HeaderedContentControl>

					<Border
						Grid.Column="1"
						Margin="0.0,7.0,0.0,0.0"
						Classes="HelpIconBorderStyle"
						ToolTip.Tip="{x:Static prop:Strings.ThisSettingWillBeAppliedAfterRestartingApplication}" />
				</Grid>
			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>
