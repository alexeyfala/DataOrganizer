<UserControl
	x:Class="DataOrganizer.Views.DatasetEditorView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="using:DataOrganizer.Behaviors"
	xmlns:componentModel="using:System.ComponentModel"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:materialIcons="using:Material.Icons.Avalonia"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:prop="using:Shared.Properties"
	xmlns:vm="using:DataOrganizer.ViewModels"
	xmlns:wrappers="using:DataOrganizer.Wrappers"
	x:DataType="vm:DatasetEditorViewModel"
	mc:Ignorable="d">

	<Grid RowDefinitions="Auto,*">
		<StackPanel
			Grid.Row="0"
			Orientation="Horizontal">
			<StackPanel.Styles>
				<Style Selector="Button">
					<Setter Property="Margin" Value="6.0,0.0" />
					<Setter Property="Theme" Value="{StaticResource MaterialFlatButton}" />
				</Style>

				<Style Selector="FlyoutPresenter">
					<Setter Property="Background" Value="{StaticResource MaterialCardBackgroundBrush}" />
					<Setter Property="Cursor" Value="Arrow" />
					<Setter Property="Theme" Value="{StaticResource MaterialFlyoutPresenter}" />
				</Style>
			</StackPanel.Styles>

			<Button
				Classes="primary"
				Content="{materialIcons:MaterialIconTextExt Kind=Plus,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.Add}">

				<Button.Flyout>
					<Flyout
						OverlayDismissEventPassThrough="True"
						Placement="Right">
						<StackPanel Orientation="Vertical">
							<wrappers:FlyoutButton
								Command="{Binding AddKeyValueCommand}"
								Header="{x:Static prop:Strings.AddKeyAndValue}"
								Icon="Plus" />

							<wrappers:FlyoutButton
								Command="{Binding AddValueCommand}"
								Header="{x:Static prop:Strings.AddValue}"
								Icon="Plus" />

							<wrappers:FlyoutButton
								Command="{Binding AddGroupCommand}"
								Header="{x:Static prop:Strings.AddGroup}"
								Icon="ShapeRectanglePlus" />
						</StackPanel>
					</Flyout>
				</Button.Flyout>
			</Button>

			<Panel Classes="VerticalSeparatorPanelStyle" />

			<Button
				Classes="primary"
				Command="{Binding ScrollToTopCommand}"
				CommandParameter="{Binding #ScrollViewer}"
				Content="{materialIcons:MaterialIconTextExt Kind=ArrowCollapseUp,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.ScrollToTop}" />

			<Button
				Classes="primary"
				Command="{Binding ScrollToEndCommand}"
				CommandParameter="{Binding #ScrollViewer}"
				Content="{materialIcons:MaterialIconTextExt Kind=ArrowCollapseDown,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.ScrollToEnd}" />

			<Panel Classes="VerticalSeparatorPanelStyle" />

			<Button
				Classes="primary"
				Command="{Binding ExpandCollapseCommand}"
				CommandParameter="{x:False}"
				Content="{materialIcons:MaterialIconTextExt Kind=ChevronDoubleUp,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.CollapseAll}" />

			<Button
				Classes="primary"
				Command="{Binding ExpandCollapseCommand}"
				CommandParameter="{x:True}"
				Content="{materialIcons:MaterialIconTextExt Kind=ChevronDoubleDown,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.ExpandAll}" />

			<Panel Classes="VerticalSeparatorPanelStyle" />

			<Button
				Classes="primary"
				Command="{Binding ShowHideCommand}"
				CommandParameter="{x:True}"
				Content="{materialIcons:MaterialIconTextExt Kind=EyeOffOutline,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.HideAll}" />

			<Button
				Classes="primary"
				Command="{Binding ShowHideCommand}"
				CommandParameter="{x:False}"
				Content="{materialIcons:MaterialIconTextExt Kind=EyeOutline,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.ShowAll}" />

			<Panel Classes="VerticalSeparatorPanelStyle" />

			<Button
				Classes="primary"
				Content="{materialIcons:MaterialIconTextExt Kind=SortAlphabeticalVariant,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.Sorting}">
				<Button.Flyout>
					<Flyout
						OverlayDismissEventPassThrough="True"
						Placement="Bottom">
						<StackPanel Orientation="Vertical">
							<StackPanel.Styles>
								<Style Selector="Button">
									<Setter Property="Margin" Value="0.0" />
								</Style>
							</StackPanel.Styles>

							<wrappers:FlyoutButton
								Command="{Binding SortAscendingDescendingCommand}"
								CommandParameter="{x:Static componentModel:ListSortDirection.Ascending}"
								Header="{x:Static prop:Strings.SortAscending}"
								Icon="SortAlphabeticalAscending" />

							<wrappers:FlyoutButton
								Command="{Binding SortAscendingDescendingCommand}"
								CommandParameter="{x:Static componentModel:ListSortDirection.Descending}"
								Header="{x:Static prop:Strings.SortDescending}"
								Icon="SortAlphabeticalDescending" />
						</StackPanel>
					</Flyout>
				</Button.Flyout>
			</Button>

			<Panel Classes="VerticalSeparatorPanelStyle" />

			<Button
				Classes="primary"
				Command="{Binding ShowInListCommand}"
				CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
				Content="{materialIcons:MaterialIconTextExt Kind=FileTree,
				                                            IconSize={StaticResource ToolBarIconSize}}"
				ToolTip.Tip="{x:Static prop:Strings.ShowInList}" />
		</StackPanel>

		<ScrollViewer
			x:Name="ScrollViewer"
			Grid.Row="1"
			Padding="0.0,0.0,10.0,0.0"
			Classes="no-auto-hide"
			HorizontalScrollBarVisibility="Disabled"
			Theme="{StaticResource MaterialModernScrollViewer}"
			VerticalScrollBarVisibility="Auto">

			<Interaction.Behaviors>
				<behaviors:DatasetAutoScrollOnDragBehavior />
			</Interaction.Behaviors>

			<ItemsRepeater
				x:Name="RecordsItemsControl"
				ItemsSource="{Binding Records, Mode=OneTime}">

				<Interaction.Behaviors>
					<EventTriggerBehavior EventName="Loaded">
						<InvokeCommandAction
							Command="{Binding ContainerLoadedCommand}"
							CommandParameter="{Binding #RecordsItemsControl}" />
					</EventTriggerBehavior>

					<behaviors:DatasetDropRecordInsideBehavior
						IsEnabled="{Binding IsReadOnly, Mode=OneWay, Converter={x:Static BoolConverters.Not}}"
						MovedCommand="{Binding RecordMovedCommand}"
						Records="{Binding Records, Mode=OneTime}" />
				</Interaction.Behaviors>

				<ItemsRepeater.Layout>
					<StackLayout
						Orientation="Vertical"
						Spacing="4.0" />
				</ItemsRepeater.Layout>

				<ItemsRepeater.ItemTemplate>
					<RecyclingElementFactory SelectTemplateKey="OnSelectRecordTemplateKey">
						<RecyclingElementFactory.Templates>
							<StaticResource
								x:Key="KeyValueRecord"
								ResourceKey="KeyValueRecordTemplate" />

							<StaticResource
								x:Key="ValueRecord"
								ResourceKey="ValueRecordTemplate" />

							<StaticResource
								x:Key="RecordsGroup"
								ResourceKey="RecordsGroupTemplate" />
						</RecyclingElementFactory.Templates>
					</RecyclingElementFactory>
				</ItemsRepeater.ItemTemplate>
			</ItemsRepeater>
		</ScrollViewer>
	</Grid>
</UserControl>
