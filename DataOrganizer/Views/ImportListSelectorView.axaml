<UserControl
	x:Class="DataOrganizer.Views.ImportListSelectorView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:prop="clr-namespace:Shared.Properties;assembly=Shared"
	xmlns:vm="using:DataOrganizer.ViewModels"
	x:DataType="vm:ImportListSelectorViewModel"
	Theme="{StaticResource DialogTheme}"
	mc:Ignorable="d">

	<Design.DataContext>
		<vm:ImportListSelectorViewModel />
	</Design.DataContext>

	<StackPanel Orientation="Vertical">
		<RadioButton Content="{x:Static prop:Strings.ReplaceTheList}" />
		
		<RadioButton Content="{x:Static prop:Strings.AddToEndOfList}" />
	</StackPanel>
</UserControl>
