<UserControl
	x:Class="DataOrganizer.Views.MultilineTextEditView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:prop="using:Shared.Properties"
	xmlns:vm="using:DataOrganizer.ViewModels"
	x:DataType="vm:MultilineTextEditViewModel"
	Theme="{StaticResource DialogTheme}"
	mc:Ignorable="d">

	<Grid
		ColumnDefinitions="*,Auto"
		RowDefinitions="*,Auto"
		RowSpacing="{StaticResource ElementSpacing}">
		<TextBox
			Grid.Row="0"
			Grid.Column="0"
			Grid.ColumnSpan="3"
			AcceptsReturn="True"
			AcceptsTab="True"
			FontSize="14.0"
			Text="{Binding Text, Mode=TwoWay}"
			TextWrapping="Wrap" />

		<UniformGrid
			Grid.Row="1"
			Grid.Column="1"
			ColumnSpacing="{StaticResource ElementSpacing}"
			Columns="2">
			<UniformGrid.Styles>
				<Style Selector="Button">
					<Setter Property="Theme" Value="{StaticResource MaterialFlatButton}" />
				</Style>
			</UniformGrid.Styles>

			<Button
				Classes="primary"
				Command="{Binding SaveCommand}"
				Content="{x:Static prop:Strings.Save}"
				IsDefault="True" />

			<Button
				Classes="primary"
				Command="{Binding CancelCommand}"
				Content="{x:Static prop:Strings.Cancel}"
				IsCancel="True" />
		</UniformGrid>
	</Grid>
</UserControl>
