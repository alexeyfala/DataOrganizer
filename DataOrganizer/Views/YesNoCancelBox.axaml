<UserControl
	x:Class="DataOrganizer.Views.YesNoCancelBox"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:prop="clr-namespace:Shared.Properties;assembly=Shared"
	xmlns:vm="using:DataOrganizer.ViewModels"
	Padding="{StaticResource DialogIndent}"
	x:DataType="vm:YesNoCancelBoxViewModel"
	mc:Ignorable="d">

	<Design.DataContext>
		<vm:YesNoCancelBoxViewModel />
	</Design.DataContext>
</UserControl>
