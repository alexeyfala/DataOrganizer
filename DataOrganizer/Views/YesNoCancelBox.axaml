<UserControl
	x:Class="DataOrganizer.Views.YesNoCancelBox"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:prop="clr-namespace:Shared.Properties;assembly=Shared"
	xmlns:vm="using:DataOrganizer.ViewModels"
	Padding="{StaticResource DialogIndent}"
	x:DataType="vm:YesNoCancelBoxViewModel"
	mc:Ignorable="d">

	<Design.DataContext>
		<vm:YesNoCancelBoxViewModel />
	</Design.DataContext>

	<Grid
		ColumnDefinitions="*,Auto"
		RowDefinitions="Auto,Auto"
		RowSpacing="{StaticResource ElementSpacing}">

		<TextBlock
			Grid.Row="0"
			Grid.Column="0"
			Grid.ColumnSpan="2"
			HorizontalAlignment="Center"
			Text="{Binding Text, Mode=OneWay}"
			TextTrimming="CharacterEllipsis" />

		<UniformGrid
			Grid.Row="1"
			Grid.Column="1"
			ColumnSpacing="{StaticResource ElementSpacing}"
			Columns="3">
			<UniformGrid.Styles>
				<Style Selector="Button">
					<Setter Property="Theme" Value="{StaticResource MaterialFlatButton}" />
				</Style>
			</UniformGrid.Styles>

			<Button
				Classes="primary"
				Command="{Binding YesButtonPressed}"
				Content="{x:Static prop:Strings.Yes}"
				IsDefault="True" />

			<Button
				Classes="primary"
				Command="{Binding NoButtonPressed}"
				Content="{x:Static prop:Strings.No}"
				IsCancel="True"
				IsVisible="{Binding NoButtonVisible, Mode=OneWay}" />

			<Button
				Classes="primary"
				Command="{Binding CancelButtonPressed}"
				Content="{x:Static prop:Strings.Cancel}"
				IsCancel="True"
				IsVisible="{Binding CancelButtonVisible, Mode=OneWay}" />
		</UniformGrid>
	</Grid>
</UserControl>
