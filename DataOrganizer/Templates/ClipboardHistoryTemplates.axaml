<ResourceDictionary
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="using:DataOrganizer.Behaviors"
	xmlns:clipboard="using:DataOrganizer.DTO.Clipboard"
	xmlns:html="using:TheArtOfDev.HtmlRenderer.Avalonia"
	xmlns:materialIcons="using:Material.Icons.Avalonia"
	xmlns:prop="using:Shared.Properties"
	xmlns:system="using:System"
	xmlns:templateSelectors="using:DataOrganizer.Templates.TemplateSelectors"
	xmlns:vm="using:DataOrganizer.ViewModels">

	<system:Double x:Key="TextEntryMaxHeight">100.0</system:Double>
	<system:Double x:Key="ImageEntryMaxWidth">160.0</system:Double>
	<system:Double x:Key="ImageEntryMaxHeight">120.0</system:Double>

	<SolidColorBrush
		x:Key="SearchHighlightBrush"
		Color="Yellow" />

	<SolidColorBrush
		x:Key="SearchHighlightForegroundBrush"
		Color="Black" />

	<!-- ClipboardTextEntryTemplate -->
	<DataTemplate
		x:Key="ClipboardTextEntryTemplate"
		x:DataType="clipboard:ClipboardTextEntry">
		<ScrollViewer
			MaxHeight="{StaticResource TextEntryMaxHeight}"
			HorizontalScrollBarVisibility="Disabled"
			IsHitTestVisible="False"
			VerticalScrollBarVisibility="Disabled">
			<TextBlock
				VerticalAlignment="Center"
				TextTrimming="CharacterEllipsis"
				TextWrapping="Wrap">
				<Interaction.Behaviors>
					<behaviors:SearchHighlightBehavior
						HighlightBrush="{StaticResource SearchHighlightBrush}"
						HighlightForeground="{StaticResource SearchHighlightForegroundBrush}"
						Query="{Binding $parent[Window].((vm:CustomClipboardViewModel)DataContext).SearchText}"
						SourceText="{Binding Text, Mode=OneTime}" />
				</Interaction.Behaviors>
			</TextBlock>
		</ScrollViewer>
	</DataTemplate>

	<!-- ClipboardImageEntryTemplate -->
	<DataTemplate
		x:Key="ClipboardImageEntryTemplate"
		x:DataType="clipboard:ClipboardImageEntry">
		<Image
			MaxWidth="{StaticResource ImageEntryMaxWidth}"
			MaxHeight="{StaticResource ImageEntryMaxHeight}"
			HorizontalAlignment="Left"
			Source="{Binding ImagePreview, Mode=OneTime}"
			Stretch="Uniform" />
	</DataTemplate>

	<!-- ClipboardFilesEntryTemplate -->
	<DataTemplate
		x:Key="ClipboardFilesEntryTemplate"
		x:DataType="clipboard:ClipboardFilesEntry">
		<TextBlock
			Text="{Binding Preview, Mode=OneTime}"
			TextTrimming="CharacterEllipsis"
			TextWrapping="NoWrap" />
	</DataTemplate>

	<!-- ClipboardEntryItemTemplate -->
	<DataTemplate
		x:Key="ClipboardEntryItemTemplate"
		x:DataType="clipboard:ClipboardHistoryEntryBase">
		<Button
			Padding="6.0"
			HorizontalAlignment="Stretch"
			HorizontalContentAlignment="Stretch"
			Background="{StaticResource MaterialDividerBrush}"
			Classes.active="{Binding IsActive}"
			Command="{Binding $parent[Window].((vm:CustomClipboardViewModel)DataContext).RestoreEntryCommand}"
			CommandParameter="{Binding}"
			Cursor="Arrow"
			ToolTip.Tip="{Binding ContentToolTip, Mode=OneTime}">

			<!-- Accent left bar marks the entry currently held in the system clipboard. -->
			<Button.Styles>
				<Style Selector="Button.active">
					<Setter Property="BorderBrush" Value="{StaticResource MaterialPrimaryMidBrush}" />
					<Setter Property="BorderThickness" Value="4.0,0.0,0.0,0.0" />
				</Style>
			</Button.Styles>

			<Interaction.Behaviors>
				<behaviors:CloseWindowOnClickBehavior
					KeepOpen="{Binding $parent[Window].((vm:CustomClipboardViewModel)DataContext).KeepOpen}"
					Window="{Binding $parent[Window]}" />
			</Interaction.Behaviors>

			<Panel>
				<ContentControl
					Classes.revealed="{Binding #RevealEye.IsChecked, Mode=OneWay}"
					Classes.sensitive="{ReflectionBinding IsSensitive,
					                                      Mode=OneTime}"
					Content="{Binding}">
					<ContentControl.Styles>
						<Style Selector="ContentControl.sensitive:not(.revealed)">
							<Setter Property="Effect">
								<BlurEffect Radius="6.0" />
							</Setter>
						</Style>
					</ContentControl.Styles>

					<ContentControl.ContentTemplate>
						<templateSelectors:ClipboardEntryTemplateSelector PlainTextTemplate="{StaticResource ClipboardTextEntryTemplate}">
							<StaticResource ResourceKey="ClipboardImageEntryTemplate" />

							<StaticResource ResourceKey="ClipboardFilesEntryTemplate" />
						</templateSelectors:ClipboardEntryTemplateSelector>
					</ContentControl.ContentTemplate>
				</ContentControl>

				<Grid
					HorizontalAlignment="Right"
					VerticalAlignment="Stretch"
					RowDefinitions="Auto,*,Auto"
					RowSpacing="2.0">

					<StackPanel
						Grid.Row="0"
						HorizontalAlignment="Right"
						Orientation="Horizontal"
						Spacing="2.0">

						<!--
							Reserve the row height via the always-visible badge, so toggling the pin's
							visibility on hover does not change the entry height.
						-->
						<StackPanel.MinHeight>
							<Binding
								ElementName="TypeGlyphBadge"
								Path="Bounds.Height" />
						</StackPanel.MinHeight>

						<ToggleButton
							Padding="3.0"
							Background="{StaticResource MaterialCardBackgroundBrush}"
							Classes="primary"
							Cursor="Hand"
							IsChecked="{Binding IsPinned, Mode=OneWay}"
							Theme="{StaticResource MaterialFlatButton}">

							<ToggleButton.IsVisible>
								<MultiBinding Converter="{x:Static BoolConverters.Or}">
									<Binding
										Mode="OneWay"
										Path="IsPinned" />

									<Binding
										Path="IsPointerOver"
										RelativeSource="{RelativeSource AncestorType=Button}" />
								</MultiBinding>
							</ToggleButton.IsVisible>

							<Interaction.Behaviors>
								<!--
									Command via Click trigger, not Button.Command: HandleClickBehavior marks the click
									handled (to block bubbling), and Button.OnClick skips Command once handled.
								-->
								<EventTriggerBehavior EventName="Click">
									<InvokeCommandAction
										Command="{Binding $parent[Window].((vm:CustomClipboardViewModel)DataContext).TogglePinCommand}"
										CommandParameter="{Binding}" />
								</EventTriggerBehavior>

								<behaviors:HandleClickBehavior />
							</Interaction.Behaviors>

							<ToggleButton.Styles>
								<Style Selector="ToggleButton:not(:checked)">
									<Setter Property="ToolTip.Tip" Value="{x:Static prop:Strings.Pin}" />
								</Style>

								<Style Selector="ToggleButton:checked">
									<Setter Property="ToolTip.Tip" Value="{x:Static prop:Strings.Unpin}" />
								</Style>

								<Style Selector="ToggleButton:not(:checked) materialIcons|MaterialIcon">
									<Setter Property="Kind" Value="PinOutline" />
								</Style>

								<Style Selector="ToggleButton:checked materialIcons|MaterialIcon">
									<Setter Property="Kind" Value="Pin" />
								</Style>
							</ToggleButton.Styles>

							<materialIcons:MaterialIcon
								Width="12.5"
								Height="12.5" />
						</ToggleButton>

						<Button
							Padding="3.0"
							Background="{StaticResource MaterialCardBackgroundBrush}"
							Command="{Binding $parent[Window].((vm:CustomClipboardViewModel)DataContext).OpenUrlCommand}"
							CommandParameter="{ReflectionBinding Url,
							                                     Mode=OneTime}"
							Content="🌎"
							Cursor="Hand"
							FontFamily="Segoe UI Emoji"
							FontSize="12.0"
							IsVisible="{Binding IsUrl}"
							ToolTip.Tip="{x:Static prop:Strings.OpenInBrowser}" />
					</StackPanel>

					<StackPanel
						Grid.Row="2"
						HorizontalAlignment="Right"
						Orientation="Horizontal"
						Spacing="2.0">
						<ToggleButton
							x:Name="RevealEye"
							Padding="3.0"
							VerticalAlignment="Center"
							Background="{StaticResource MaterialCardBackgroundBrush}"
							Cursor="Hand"
							Theme="{StaticResource MaterialFlatButton}">

							<ToggleButton.IsVisible>
								<MultiBinding Converter="{x:Static BoolConverters.And}">
									<ReflectionBinding
										Mode="OneTime"
										Path="IsSensitive">
										<!--
											Real bool fallback for entries without IsSensitive (image / files); UnsetValue would be
											dropped by BoolConverters.And and leak the eye onto them.
										-->
										<ReflectionBinding.FallbackValue>
											<system:Boolean>False</system:Boolean>
										</ReflectionBinding.FallbackValue>
									</ReflectionBinding>

									<Binding
										Path="IsPointerOver"
										RelativeSource="{RelativeSource AncestorType=Button}" />

									<!-- Hide the eye while the pointer is over the type-glyph badge. -->
									<Binding
										ElementName="TypeGlyphBadge"
										Path="!IsPointerOver" />
								</MultiBinding>
							</ToggleButton.IsVisible>

							<Interaction.Behaviors>
								<behaviors:HandleClickBehavior />
							</Interaction.Behaviors>

							<ToggleButton.Styles>
								<Style Selector="ToggleButton:not(:checked)">
									<Setter Property="ToolTip.Tip" Value="{x:Static prop:Strings.ShowContents}" />
								</Style>

								<Style Selector="ToggleButton:checked">
									<Setter Property="ToolTip.Tip" Value="{x:Static prop:Strings.HideContents}" />
								</Style>

								<Style Selector="ToggleButton:not(:checked) materialIcons|MaterialIcon">
									<Setter Property="Kind" Value="EyeOutline" />
								</Style>

								<Style Selector="ToggleButton:checked materialIcons|MaterialIcon">
									<Setter Property="Kind" Value="EyeOffOutline" />
								</Style>
							</ToggleButton.Styles>

							<materialIcons:MaterialIcon
								Width="12.5"
								Height="12.5" />
						</ToggleButton>

						<Border
							x:Name="TypeGlyphBadge"
							Padding="3.0"
							HorizontalAlignment="Right"
							VerticalAlignment="Center"
							Background="{StaticResource MaterialCardBackgroundBrush}"
							BorderBrush="{StaticResource MaterialDividerBrush}"
							BorderThickness="1.0"
							CornerRadius="4.0"
							ToolTip.Tip="{Binding TypeToolTip, Mode=OneTime}">

							<Border.Styles>
								<Style Selector="Border:pointerover">
									<Setter Property="Opacity" Value="0.5" />
								</Style>
							</Border.Styles>

							<TextBlock
								FontFamily="Segoe UI Emoji"
								FontSize="12.0"
								Text="{Binding TypeGlyph, Mode=OneTime}" />
						</Border>
					</StackPanel>
				</Grid>
			</Panel>
		</Button>
	</DataTemplate>
</ResourceDictionary>
