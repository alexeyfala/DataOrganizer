<!--
	Override of Material.Avalonia's MaterialSideSheet ControlTheme.
	
	Source: https://github.com/AvaloniaCommunity/Material.Avalonia/blob/master/Material.Styles/Controls/SideSheet.axaml
	
	Change vs. original: PART_SideSheetPanel is a DockPanel (was StackPanel),
	so SideSheetContent receives a finite height and its own ScrollViewer can activate.
-->
<ResourceDictionary
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:converters="using:Material.Styles.Converters"
	xmlns:materialControls="using:Material.Styles.Controls"
	xmlns:parameters="using:Material.Styles.Converters.Parameters"
	xmlns:system="using:System">

	<SineEaseInOut x:Key="DataOrganizerSideSheetEasing" />
	
	<parameters:MarginMultiplyParameter
		x:Key="DataOrganizerSideSheetLeftMarginParam"
		LeftMultiplier="-1" />
	
	<parameters:MarginMultiplyParameter
		x:Key="DataOrganizerSideSheetRightMarginParam"
		RightMultiplier="-1" />
	
	<converters:MarginMultiplyConverter x:Key="DataOrganizerSideSheetMarginCreator" />

	<ControlTheme
		x:Key="ScrollableSideSheet"
		TargetType="materialControls:SideSheet">
		<Setter Property="SideSheetWidth" Value="320" />
		<Setter Property="SideSheetPadding" Value="16" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="SideSheetDirection" Value="Right" />
		<Setter Property="Background" Value="{DynamicResource MaterialPaperBrush}" />
		<Setter Property="SideSheetHeaderTemplate">
			<DataTemplate>
				<TextBlock
					Classes="Headline6"
					Text="{Binding ., DataType={x:Type system:Object}}" />
			</DataTemplate>
		</Setter>
		<Setter Property="Template">
			<ControlTemplate>
				<Border
					Name="PART_RootBorder"
					Background="{TemplateBinding Background}"
					BorderBrush="{TemplateBinding BorderBrush}"
					BorderThickness="{TemplateBinding BorderThickness}"
					ClipToBounds="False">
					<DockPanel
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch">
						<Border
							Name="PART_SideSheet"
							Width="{TemplateBinding SideSheetWidth}"
							Padding="{TemplateBinding SideSheetPadding}">
							<DockPanel
								Name="PART_SideSheetPanel"
								LastChildFill="True">
								<DockPanel
									Name="PART_HeaderPanel"
									DockPanel.Dock="Top">
									<Button
										Name="PART_CloseButton"
										DockPanel.Dock="Right"
										IsVisible="{TemplateBinding SideSheetCanClose}"
										Theme="{StaticResource MaterialIconButton}">
										<materialControls:MaterialInternalIcon
											Name="PART_Icon"
											Kind="Close" />
									</Button>
									<ContentPresenter
										Name="PART_HeaderContentPresenter"
										Content="{TemplateBinding SideSheetHeader,
										                          Mode=OneWay}"
										ContentTemplate="{TemplateBinding SideSheetHeaderTemplate}"
										DockPanel.Dock="Left" />
								</DockPanel>
								<ContentPresenter
									Name="PART_SideContentPresenter"
									Content="{TemplateBinding SideSheetContent}"
									ContentTemplate="{TemplateBinding SideSheetContentTemplate}"
									IsEnabled="{TemplateBinding SideSheetOpened}" />
							</DockPanel>
						</Border>
						<Panel Name="PART_ContentPanel">
							<ContentPresenter
								Name="PART_ContentPresenter"
								Margin="{TemplateBinding Padding}"
								Content="{TemplateBinding Content}"
								ContentTemplate="{TemplateBinding ContentTemplate}" />
							<Border
								Name="PART_Scrim"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch"
								Background="Black"
								IsHitTestVisible="{TemplateBinding SideSheetOpened}" />
						</Panel>
					</DockPanel>
				</Border>
			</ControlTemplate>
		</Setter>

		<Style Selector="^:not(.no-transitions) /template/ Border#PART_Scrim">
			<Setter Property="Transitions">
				<Transitions>
					<DoubleTransition
						Easing="{StaticResource DataOrganizerSideSheetEasing}"
						Property="Opacity"
						Duration="0:0:0.3" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="^:not(.no-transitions) /template/ Border#PART_SideSheet">
			<Setter Property="Transitions">
				<Transitions>
					<ThicknessTransition
						Easing="{StaticResource DataOrganizerSideSheetEasing}"
						Property="Margin"
						Duration="0:0:0.3" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="^ /template/ Border#PART_Scrim">
			<Setter Property="Opacity" Value="0" />
		</Style>

		<Style Selector="^:left:closed /template/ Border#PART_SideSheet">
			<Setter Property="Margin" Value="{Binding $self.Width, Converter={StaticResource DataOrganizerSideSheetMarginCreator}, ConverterParameter={StaticResource DataOrganizerSideSheetLeftMarginParam}}" />
		</Style>

		<Style Selector="^:left /template/ Border#PART_ContentPanel">
			<Setter Property="DockPanel.Dock" Value="Left" />
		</Style>

		<Style Selector="^:right:closed /template/ Border#PART_SideSheet">
			<Setter Property="Margin" Value="{Binding $self.Width, Converter={StaticResource DataOrganizerSideSheetMarginCreator}, ConverterParameter={StaticResource DataOrganizerSideSheetRightMarginParam}}" />
		</Style>

		<Style Selector="^:right /template/ Border#PART_ContentPanel">
			<Setter Property="DockPanel.Dock" Value="Right" />
		</Style>

		<!-- Desktop mode should disable the scrim part -->
		<Style Selector="^:not(:mobile) /template/ Border#PART_Scrim">
			<Setter Property="IsEnabled" Value="False" />
			<Setter Property="IsVisible" Value="False" />
		</Style>

		<Style Selector="^:not(:mobile) /template/ Border#PART_SideSheet">
			<Setter Property="BorderBrush" Value="{DynamicResource MaterialDividerBrush}" />
		</Style>

		<Style Selector="^:left:not(:mobile) /template/ Border#PART_SideSheet">
			<Setter Property="BorderThickness" Value="0,0,1,0" />
			<Setter Property="DockPanel.Dock" Value="Left" />
		</Style>

		<Style Selector="^:right:not(:mobile) /template/ Border#PART_SideSheet">
			<Setter Property="BorderThickness" Value="1,0,0,0" />
			<Setter Property="DockPanel.Dock" Value="Right" />
		</Style>

		<Style Selector="^:open /template/ Border#PART_Scrim">
			<Setter Property="Opacity" Value="0.32" />
		</Style>

		<Style Selector="^ /template/ DockPanel#PART_SideSheetPanel > DockPanel#PART_HeaderPanel > Button#PART_CloseButton.Icon">
			<Setter Property="Height" Value="36" />
			<Setter Property="Width" Value="36" />
			<Setter Property="Margin" Value="-6" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialBodyBrush}" />
		</Style>

		<Style Selector="^ /template/ DockPanel#PART_SideSheetPanel > DockPanel#PART_HeaderPanel > Button#PART_CloseButton > materialControls|MaterialInternalIcon#PART_Icon">
			<Setter Property="Height" Value="24" />
			<Setter Property="Width" Value="24" />
		</Style>

		<Style Selector="^ /template/ DockPanel#PART_SideSheetPanel > ContentPresenter#PART_SideContentPresenter">
			<Setter Property="Margin" Value="0,5,0,0" />
		</Style>
	</ControlTheme>
</ResourceDictionary>
