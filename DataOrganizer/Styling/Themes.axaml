<ResourceDictionary
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:materialIcons="using:Material.Icons.Avalonia"
	xmlns:prop="using:Shared.Properties">

	<ControlTheme
		x:Key="CustomClipboardButtonTheme"
		BasedOn="{StaticResource MaterialFlatButton}"
		TargetType="Button">
		<Setter Property="Content">
			<Setter.Value>
				<Template>
					<materialIcons:MaterialIcon
						Width="{StaticResource ToolBarIconSize}"
						Height="{StaticResource ToolBarIconSize}"
						Kind="ClipboardOutline" />
				</Template>
			</Setter.Value>
		</Setter>
		<Setter Property="ToolTip.Tip">
			<Setter.Value>
				<Template>
					<ToolTip>
						<TextBlock>
							<Run Text="{x:Static prop:Strings.Clipboard}" />
						</TextBlock>
					</ToolTip>
				</Template>
			</Setter.Value>
		</Setter>
	</ControlTheme>

	<ControlTheme
		x:Key="DialogTheme"
		TargetType="UserControl">
		<Setter Property="MinWidth" Value="300.0" />
		<Setter Property="Padding" Value="{StaticResource DialogIndent}" />
	</ControlTheme>

	<!-- Not used -->
	<ControlTheme
		x:Key="CopyToClipboardButtonTheme"
		BasedOn="{StaticResource MaterialFlatButton}"
		TargetType="Button">
		<Setter Property="ToolTip.Tip" Value="{x:Static prop:Strings.Copy}" />
		<Setter Property="Content">
			<Setter.Value>
				<Template>
					<materialIcons:MaterialIcon Kind="ContentCopy" />
				</Template>
			</Setter.Value>
		</Setter>
	</ControlTheme>
</ResourceDictionary>
