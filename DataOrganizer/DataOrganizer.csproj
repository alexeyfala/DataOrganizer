<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<WarningsAsErrors>nullable</WarningsAsErrors>
		<LangVersion>latest</LangVersion>
		<AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
		<RootNamespace>DataOrganizer</RootNamespace>
		<AssemblyName>DataOrganizerMain</AssemblyName>
		<Version>2.0.0-Preview1</Version>
		<FileVersion>2.0.0</FileVersion>
		<AssemblyVersion>2.0.0</AssemblyVersion>
	</PropertyGroup>

	<ItemGroup>
		<AvaloniaResource Include="Assets\**" />
	</ItemGroup>

	<ItemGroup>
		<AvaloniaXaml Remove="Assets\DataTemplates.axaml" />
		<AvaloniaXaml Remove="Assets\Resources.axaml" />
		<AvaloniaXaml Remove="Assets\Styles.axaml" />
		<AvaloniaXaml Remove="Assets\Themes.axaml" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Avalonia" Version="11.3.11" />
		<PackageReference Include="Avalonia.AvaloniaEdit" Version="11.4.1" />
		<PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.11" />
		<!--Condition below is needed to remove Avalonia.Diagnostics package from build output in Release configuration.-->
		<PackageReference Include="Avalonia.Diagnostics" Version="11.3.11">
			<IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
			<PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.11" />
		<PackageReference Include="Avalonia.Themes.Simple" Version="11.3.11" />
		<PackageReference Include="Baksteen.Extensions.DeepCopy" Version="1.0.5" />
		<PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
		<PackageReference Include="BinToss.GroupBox.Avalonia" Version="1.0.0" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
		<PackageReference Include="Comparation" Version="0.1.7" />
		<PackageReference Include="DialogHost.Avalonia" Version="0.10.4" />
		<PackageReference Include="DynamicData" Version="9.4.1" />
		<PackageReference Include="Mapster" Version="7.4.0" />
		<PackageReference Include="Mapster.DependencyInjection" Version="1.0.1" />
		<PackageReference Include="Material.Avalonia" Version="3.13.4" />
		<PackageReference Include="Material.Icons.Avalonia" Version="2.4.1" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.2" />
		<PackageReference Include="NSec.Cryptography" Version="25.4.0" />
		<PackageReference Include="OSVersionExt.NetStd" Version="3.0.1" />
		<PackageReference Include="Serilog.Enrichers.Demystifier" Version="1.0.3" />
		<PackageReference Include="Serilog.Exceptions" Version="8.4.0" />
		<PackageReference Include="Serilog.Sinks.Async" Version="2.1.0" />
		<PackageReference Include="Serilog.Sinks.FileEx" Version="5.1.8" />
		<PackageReference Include="SharpHook" Version="7.1.1" />
		<PackageReference Include="System.Reactive" Version="6.1.0" />
		<PackageReference Include="Tulesha.ToolBarControls.Avalonia" Version="11.3.6" />
		<PackageReference Include="Xaml.Behaviors" Version="11.3.9.4" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Repository\Repository.csproj" />
		<ProjectReference Include="..\Shared\Shared.csproj" />
	</ItemGroup>

	<ItemGroup>
		<AvaloniaResource Update="Assets\DataTemplates.axaml">
			<SubType>Designer</SubType>
		</AvaloniaResource>
		<AvaloniaResource Update="Assets\Resources.axaml">
			<SubType>Designer</SubType>
		</AvaloniaResource>
		<AvaloniaResource Update="Assets\Styles.axaml">
			<SubType>Designer</SubType>
		</AvaloniaResource>
		<AvaloniaResource Update="Assets\Themes.axaml">
			<SubType>Designer</SubType>
		</AvaloniaResource>
	</ItemGroup>

	<ItemGroup>
		<Compile Update="Views\EditFilesView.axaml.cs">
			<DependentUpon>EditFilesView.axaml</DependentUpon>
		</Compile>
		<Compile Update="Views\EmbeddedFileEditorView.axaml.cs">
			<DependentUpon>EmbeddedFileEditorView.axaml</DependentUpon>
		</Compile>
		<Compile Update="Windows\ConsoleWindow.axaml.cs">
			<DependentUpon>ConsoleWindow.axaml</DependentUpon>
		</Compile>
		<Compile Update="Windows\EditorWindow.axaml.cs">
			<DependentUpon>EditorWindow.axaml</DependentUpon>
		</Compile>
		<Compile Update="Windows\FavoritesWindow.axaml.cs">
			<DependentUpon>FavoritesWindow.axaml</DependentUpon>
		</Compile>
	</ItemGroup>
</Project>
