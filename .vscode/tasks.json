				"/consoleloggerparameters:NoSummary"
			],
			"command": "dotnet",
			"options": {
				"cwd": "${workspaceFolder}/${config:app.name}.MacOS"
			},
			"group": "build",
			// Builds the macOS app head in Release. Used as preLaunchTask for the Release launch.
			"label": "build-macos-release",
			"problemMatcher": "$msCompile",
			"type": "process"
		}
		*/
