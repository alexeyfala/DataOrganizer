{
	"version": "2.0.0",
	"tasks": [
		{
			"args": [
				"build",
				"${workspaceFolder}/DataOrganizer.MacOS/DataOrganizer.MacOS.csproj",
				"-c",
				"Debug",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"command": "dotnet",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			// Builds the macOS app head in Debug. Used as preLaunchTask for the Debug launch.
			"label": "build-macos",
			"problemMatcher": "$msCompile",
			"type": "process"
		},
		{
			"args": [
				"build",
				"${workspaceFolder}/DataOrganizer.MacOS/DataOrganizer.MacOS.csproj",
				"-c",
				"Release",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"command": "dotnet",
			"group": "build",
			// Builds the macOS app head in Release. Used as preLaunchTask for the Release launch.
			"label": "build-macos-release",
			"problemMatcher": "$msCompile",
			"type": "process"
		}
	]
}
