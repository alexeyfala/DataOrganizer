			"options": {
				"cwd": "${workspaceFolder}/${config:app.name}.MacOS"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			// Builds the macOS app head in Debug. Used as preLaunchTask for the Debug launch.
			"label": "build-macos",
			"problemMatcher": "$msCompile",
			"type": "process"
		},
		{
