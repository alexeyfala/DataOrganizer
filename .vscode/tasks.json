{
	"version": "2.0.0",
	"tasks": [
		{
			"args": [
				"build",
				"${workspaceFolder}/DataOrganizer.MacOS/DataOrganizer.MacOS.csproj",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"command": "dotnet",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			// Builds the macOS app head (net10.0-macos). Used as preLaunchTask for debugging.
			"label": "build-macos",
			"problemMatcher": "$msCompile",
			"type": "process"
		}
	]
}
