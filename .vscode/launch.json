{
	"version": "0.2.0",
	"configurations": [
		{
			// Launches the macOS app head under the debugger. Runs the executable inside the .app bundle.
			"name": ".NET Launch (macOS)",
			"type": "coreclr",
			"request": "launch",
			"preLaunchTask": "build-macos",
			"program": "${workspaceFolder}/DataOrganizer.MacOS/bin/Debug/net10.0-macos/osx-x64/DataOrganizer.app/Contents/MacOS/DataOrganizer",
			"args": [],
			"cwd": "${workspaceFolder}/DataOrganizer.MacOS",
			"console": "internalConsole",
			"stopAtEntry": false
		}
	]
}
