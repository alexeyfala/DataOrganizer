{
	"version": "0.2.0",
	"configurations": [
		{
			"args": [],
			"console": "internalConsole",
			"cwd": "${workspaceFolder}/DataOrganizer.MacOS",
			// Launches the macOS app head (Debug). Runs the executable inside the .app bundle.
			"name": ".NET Launch (macOS, Debug)",
			"preLaunchTask": "build-macos",
			"program": "${workspaceFolder}/DataOrganizer.MacOS/bin/Debug/net10.0-macos/osx-x64/DataOrganizer.app/Contents/MacOS/DataOrganizer",
			"request": "launch",
			"stopAtEntry": false,
			"type": "coreclr"
		},
		{
			"args": [],
			"console": "internalConsole",
			"cwd": "${workspaceFolder}/DataOrganizer.MacOS",
			// Same as above but Release (bin/Release + build-macos-release task).
			"name": ".NET Launch (macOS, Release)",
			"preLaunchTask": "build-macos-release",
			"program": "${workspaceFolder}/DataOrganizer.MacOS/bin/Release/net10.0-macos/osx-x64/DataOrganizer.app/Contents/MacOS/DataOrganizer",
			"request": "launch",
			"stopAtEntry": false,
			"type": "coreclr"
		}
	]
}
